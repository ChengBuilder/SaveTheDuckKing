{
  "name": "save-the-duck-king-tooling",
  "private": true,
  "description": "Tooling for official WeChat mini game checks and CI workflows.",
  "scripts": {
    "guardrails": "node architecture/tools/run-guardrails.js",
    "runtime:normalize-module-filenames": "node architecture/tools/normalize-runtime-module-filenames.js",
    "source:migrate-runtime": "node architecture/tools/migrate-runtime-to-source-project.js",
    "source:migrate-runtime:clean": "node architecture/tools/migrate-runtime-to-source-project.js --clean",
    "runtime:repack-from-source": "node architecture/tools/repack-runtime-modules-from-source.js",
    "source:build": "npm run runtime:normalize-module-filenames && npm run runtime:repack-from-source && npm run guardrails",
    "assets:restore-hashed": "node architecture/tools/restore-hashed-assets.js",
    "reconstruct:maintainable": "node architecture/tools/reconstruct-maintainable-project.js",
    "reconstruct:maintainable:clean": "node architecture/tools/reconstruct-maintainable-project.js --clean",
    "assets:prune-legacy-hash-layout": "node architecture/tools/prune-legacy-hash-layout.js",
    "assets:check-config-integrity": "node architecture/tools/check-config-version-asset-integrity.js --strict-shard",
    "wechat:code-package:check": "node architecture/tools/check-wechat-code-package-limits.js",
    "wechat:official:check": "node architecture/tools/run-wechat-official-checks.js",
    "wechat:official:fix": "node architecture/tools/run-wechat-official-checks.js --fix",
    "wechat:ci:doctor": "node architecture/tools/run-wechat-ci.js doctor",
    "wechat:ci:preview": "node architecture/tools/run-wechat-ci.js preview",
    "wechat:ci:upload": "node architecture/tools/run-wechat-ci.js upload",
    "wechat:ci:pack-npm": "node architecture/tools/run-wechat-ci.js pack-npm",
    "wechat:test:doctor": "node architecture/tools/run-minigame-test-doctor.js",
    "wechat:test:run": "node architecture/tools/run-minigame-test.js",
    "cocos:build:wechat": "node architecture/tools/build-cocos-wechat-runtime.js"
  },
  "devDependencies": {
    "miniprogram-ci": "2.1.31",
    "prettier": "^2.8.8"
  },
