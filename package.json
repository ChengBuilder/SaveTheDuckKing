{
  "name": "save-the-duck-king-tooling",
  "private": true,
  "description": "Tooling for official WeChat mini game checks and CI workflows.",
  "scripts": {
    "guardrails": "node architecture/tools/run-guardrails.js",
    "wechat:code-package:check": "node architecture/tools/check-wechat-code-package-limits.js",
    "wechat:official:check": "node architecture/tools/run-wechat-official-checks.js",
